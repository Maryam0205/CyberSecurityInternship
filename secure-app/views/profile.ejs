<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Profile — UserHub Secure</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="brand">
        <span class="brand-mark">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
        </span>
        <span>UserHub</span>
        <span class="brand-secure-badge">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
          Hardened
        </span>
      </a>
      <div class="nav-links">
        <a class="nav-link active" href="/profile">Profile</a>
        <a class="nav-link" href="/users">Members</a>
        <a class="nav-link" href="/logout">Logout</a>
      </div>
    </div>
  </nav>

  <div class="container">
    <div class="page-header">
      <div class="avatar"><%= user.username.charAt(0).toUpperCase() %></div>
      <div class="page-title">
        <h1><%= user.username %></h1>
        <p>Manage your account information and bio.</p>
      </div>
    </div>

    <div class="alert alert-info" style="margin-bottom: 1.5rem;">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      <span>Your session is signed with JWT and stored in an HttpOnly, SameSite=Strict cookie. Bio content is HTML-escaped on render.</span>
    </div>

    <div class="profile-grid">
      <div class="card">
        <h2>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="16" x2="12" y2="12"/><line x1="12" y1="8" x2="12.01" y2="8"/></svg>
          Account information
        </h2>
        <p class="card-sub">Your basic account details.</p>
        <div class="info-row">
          <span class="label">Username</span>
          <span class="value"><%= user.username %></span>
        </div>
        <div class="info-row">
          <span class="label">Email</span>
          <span class="value"><%= user.email %></span>
        </div>
        <div class="info-row">
          <span class="label">Account ID</span>
          <span class="value">#<%= user.id %></span>
        </div>
      </div>

      <div class="card">
        <h2>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>
          Your bio
        </h2>
        <p class="card-sub">Tell the community a bit about yourself. (Rendered HTML-escaped.)</p>

        <!-- <%%= %> escapes everything — XSS payloads become literal text. -->
        <div class="bio-display"><%= user.bio %></div>

        <form method="POST" action="/profile">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
          <div class="form-group">
            <label class="form-label" for="bio">Update bio</label>
            <textarea class="form-textarea" id="bio" name="bio" maxlength="1000" placeholder="Write something about yourself..."><%= user.bio %></textarea>
          </div>
          <button type="submit" class="btn btn-primary">Save changes</button>
        </form>
      </div>
    </div>
  </div>
</body>
</html>
