# Copy this file to `.env` and fill in real values before running in production.
# `.env` itself is gitignored.

# JWT signing secret. Use a long random string in production (e.g. `openssl rand -hex 32`).
JWT_SECRET=replace-me-with-a-long-random-secret

# Port to listen on.
PORT=3000

# Set to "production" in production so cookies are flagged Secure and stack traces are hidden.
NODE_ENV=development
