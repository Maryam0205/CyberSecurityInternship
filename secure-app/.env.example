# Copy to .env and fill in real values. NEVER commit .env.
NODE_ENV=development
PORT=3000

# JWT signing secret — 32+ random bytes. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-me-with-a-long-random-secret

# Session secret for OAuth handshake (passport). Same generation as above.
SESSION_SECRET=replace-me-with-another-long-random-secret

# Comma-separated list of allowed origins for CORS on the /api/* surface.
# Use exact origins. NEVER use "*" together with credentials.
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Comma-separated list of valid API keys for machine-to-machine /api callers.
# Each key should be 32+ random bytes. Rotate by appending new keys, then
# removing old ones once clients have migrated.
API_KEYS=

# Google OAuth 2.0 credentials. Register an OAuth client at
# https://console.cloud.google.com/apis/credentials and add
# http://localhost:3000/auth/google/callback as an authorized redirect URI.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# When set, the app trusts X-Forwarded-* headers (use behind a reverse proxy
# only — never expose the app directly with this on, or rate-limiter and
# req.ip can be spoofed).
TRUST_PROXY=
