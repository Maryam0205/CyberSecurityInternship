{
  "name": "secure-user-management",
  "version": "2.0.0",
  "description": "Hardened User Management System with Week 4-6 security upgrades (rate limiting, CORS, API keys, OAuth, CSRF, CSP/HSTS, monitoring, audits).",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "audit": "npm audit --omit=dev --audit-level=high",
    "audit:fix": "npm audit fix"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "bcrypt": "^5.1.1",
    "better-sqlite3": "^11.3.0",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "csurf": "^1.11.0",
    "dotenv": "^16.4.5",
    "ejs": "^3.1.10",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "express-session": "^1.18.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "validator": "^13.12.0",
    "winston": "^3.14.2"
  }
}
