<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Sign up — UserHub</title>
  <link rel="stylesheet" href="/styles.css" />
</head>
<body>
  <nav class="navbar">
    <div class="navbar-inner">
      <a href="/" class="brand">
        <span class="brand-mark">U</span>
        <span>UserHub</span>
      </a>
      <div class="nav-links">
        <a class="nav-link" href="/login">Login</a>
      </div>
    </div>
  </nav>

  <div class="container-narrow">
    <div class="auth-card">
      <div class="auth-header">
        <div class="brand-mark">U</div>
        <h1>Create your account</h1>
        <p>It only takes a few seconds.</p>
      </div>

      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span><%- error %></span>
        </div>
      <% } %>

      <form method="POST" action="/signup">
        <div class="form-group">
          <label class="form-label" for="username">Username</label>
          <input class="form-input" id="username" name="username" placeholder="Pick a username" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email address</label>
          <input class="form-input" id="email" type="email" name="email" placeholder="you@example.com" required />
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input class="form-input" id="password" type="password" name="password" placeholder="Choose a password" required />
          <p class="form-hint">Use anything you like.</p>
        </div>
        <button type="submit" class="btn btn-primary btn-block">Create account</button>
      </form>

      <p class="auth-footer">Already have an account? <a href="/login">Log in</a></p>
    </div>
  </div>
</body>
</html>
